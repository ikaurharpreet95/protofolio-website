# Airtable Configuration
# These environment variables are required for form submissions to work

# Your Airtable Personal Access Token
# Get it from: https://airtable.com/create/tokens
# Minimum required scopes: data.records:write
VITE_AIRTABLE_API_KEY=your_personal_access_token_here

# Your Airtable Base ID
# Found in the URL: https://airtable.com/app/[BASE_ID]
VITE_AIRTABLE_BASE_ID=your_base_id_here

# Your Airtable Table Name
# The name of the table where contact form submissions will be stored
VITE_AIRTABLE_TABLE_NAME=website
